# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies
node_modules/
/.pnp
.pnp.*

# Bun
bun.lockb

# Testing
coverage/

# Next.js
/.next/
/out/
next-env.d.ts

# Production (standalone build output — generated by `next build`)
/.next-standalone/
build/
dist/

# Runtime logs (created by `dev`/`start` scripts via tee)
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Env / secrets — never commit
.env
.env.*
!.env.example
!.env.template

# Prisma
# Keep schema and migrations under version control; ignore the local SQLite DB
prisma/*.db
prisma/*.db-journal
*.db
*.db-journal

# Misc
.DS_Store
*.pem
.idea/
.vscode/
*.swp
*.swo

# Vercel / platform
.vercel
