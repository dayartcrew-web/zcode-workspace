# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies
node_modules/
/.pnp
.pnp.*

# Bun
bun.lockb

# Testing
coverage/

# Next.js
/.next/
/out/
next-env.d.ts

# Production (standalone build output — generated by `next build`)
/.next-standalone/
build/
dist/

# Runtime logs (created by `dev`/`start` scripts via tee)
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Env / secrets — never commit
.env
.env.*
!.env.example
!.env.template

# Prisma
# Keep schema and migrations under version control; ignore the local SQLite DB
prisma/*.db
prisma/*.db-journal
*.db
*.db-journal

# Misc
.DS_Store
*.pem
.idea/
.vscode/
*.swp
*.swo

# Vercel / platform
.vercel

# TypeScript build info
*.tsbuildinfo

# Playwright MCP / browser-automation artifacts (screenshots, snapshots, traces)
.playwright-mcp/
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# Masday workflow artifacts — local state, worktrees, reports, context packs.
# (Worktrees are full checkouts used for task isolation; never commit them.)
.masday/worktrees/
.masday/state/
.masday/context/
.masday/research/
.masday/reports/
.masday/plans/
.masday/notes/
!.masday/.gitkeep

# Local sidecar / service runtime artifacts
mini-services/node_modules/
mini-services/*.log

# OS / editor caches
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
.cache/
.temp/
tmp/

