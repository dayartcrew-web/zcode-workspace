# zcode-workspace environment variables
# Copy this file to `.env` and fill in real values.

# SQLite database URL (Prisma). The local DB is gitignored.
DATABASE_URL="file:./dev.db"

# --- Live simulation sidecar (optional) ---
# Port the mini-services/sim-server.ts sidecar listens on.
# Defaults to 4001 if unset. Must match the port the sidecar is started with.
SIM_PORT=4001

# How the Next.js client reaches the sidecar. Pick ONE:
#
#  (default, unset both)  Direct dev without a reverse proxy:
#     the client connects straight to http://localhost:<SIM_PORT>.
#     Use this for `bun run dev` + `bun run sim`.
#
#  NEXT_PUBLIC_SIM_PROXY=1  Behind the Caddy proxy (see root Caddyfile):
#     the client connects same-origin via /?XTransformPort=<SIM_PORT>,
#     and Caddy routes it to the sidecar. Mirrors examples/websocket.
#
#  NEXT_PUBLIC_SIM_URL=http://host:port  Explicit full sidecar URL
#     (overrides everything; useful for remote sidecars).
# NEXT_PUBLIC_SIM_PROXY=1
# NEXT_PUBLIC_SIM_URL=
